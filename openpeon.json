        {
          "file": "sounds/task_acknowledge_akabaneiwabuchi.mp3",
          "label": "Akabaneiwabuchi Departure Melody"
        },
        {
          "file": "sounds/task_acknowledge_akasakamitsuke.mp3",
          "label": "Akasakamitsuke Rain Shower Melody"
        },
        {
          "file": "sounds/task_acknowledge_asakusa.mp3",
          "label": "Asakusa Departure Melody"
        },
        {
          "file": "sounds/task_acknowledge_tokyo_melody_6.mp3",
          "label": "Tokyo Train Station Departure Melody 6"
        },
        {
          "file": "sounds/task_acknowledge_akihabara.mp3",
          "label": "Akihabara Departure Melody"
        },
        {
          "file": "sounds/task_acknowledge_chikatetu_narimasu.mp3",
          "label": "Chikatetu Narimasu Departure Melody"
        },
        {
          "file": "sounds/task_acknowledge_edogawabashi.mp3",
          "label": "Edogawabashi Departure Melody"
        },
        {
          "file": "sounds/task_acknowledge_fuchu_bunbunbun.mp3",
          "label": "Fuchu Bunbunbun Departure Melody"
        },
        {
          "file": "sounds/task_acknowledge_fujisawa.mp3",
          "label": "Fujisawa Departure Melody"
        },
        {
          "file": "sounds/task_acknowledge_ginza_itchome_2.mp3",
          "label": "Ginza Itchome Departure Melody 2"
        }
      ]
    },
    "task.complete": {
      "sounds": [
        {
          "file": "sounds/task_complete_next_stop_tokyo.mp3",
          "label": "Next stop is Tokyo announcement"
        },
        {
          "file": "sounds/task_complete_terminal_tokyo.mp3",
          "label": "Terminal station Tokyo announcement"
        },
        {
          "file": "sounds/task_complete_we_have_arrived.mp3",
          "label": "We have arrived announcement"
        }
      ]
