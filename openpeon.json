{
  "cesp_version": "1.0",
  "name": "japan-rail",
  "display_name": "Japan Rail",
  "version": "1.0.0",
  "description": "Japanese Train station jingles and announcements sound pack.",
  "author": {
    "name": "Adam Bullmer",
    "github": "adambullmer"
  },
  "language": "en",
  "categories": {
    "session.start": {
      "sounds": [
        {
          "file": "sounds/session_start_door_closing.mp3",
          "label": "Doors are closing announcement"
        },
        {
          "file": "sounds/session_start_departing_shortly.mp3",
          "label": "Train will depart shortly announcement"
        },
        {
          "file": "sounds/session_start_thank_you_waiting.mp3",
          "label": "Thank you for waiting announcement"
        }
      ]
    },
    "task.acknowledge": {
