      "sounds": [
        {
          "file": "sounds/task_error_yellow_line.mp3",
          "label": "Warning announcement (stand behind the yellow line)"
        },
        {
          "file": "sounds/task_error_dangerous_rushing.mp3",
          "label": "Dangerous rushing announcement"
        },
        {
          "file": "sounds/task_error_sudden_stop.mp3",
          "label": "Sudden stop warning announcement"
        },
        {
          "file": "sounds/task_error_trouble_occurred.mp3",
          "label": "Trouble occurred announcement"
        },
        {
          "file": "sounds/task_error_crossing_bell.mp3",
          "label": "Train crossing bell (Voice/Onomatopoeia)"
        },
        {
          "file": "sounds/task_error_actual_crossing_chime.mp3",
          "label": "Actual train railroad crossing chime"
        }
      ]
    },
    "task.progress": {
      "sounds": [
        {
          "file": "sounds/task_progress_train_rolling.mp3",
          "label": "Train rolling on tracks (Voice/Onomatopoeia)"
