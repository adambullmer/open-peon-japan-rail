      "sounds": [
        {
          "file": "sounds/input_required_gate_chime_1.wav",
          "label": "Ticket gate chime 1"
        },
        {
          "file": "sounds/input_required_touch_ic_card.mp3",
          "label": "Please touch your IC card announcement"
        },
        {
          "file": "sounds/input_required_charge_card.mp3",
          "label": "Please charge card announcement"
        },
        {
          "file": "sounds/input_required_crossing_intro.mp3",
          "label": "Train crossing intro"
        }
      ]
